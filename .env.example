# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in your own values.
# The `.env` file is gitignored and should NEVER be committed to the repository.
# ─────────────────────────────────────────────────────────────────────────────

# YouTube Data API v3 key (get it from https://console.cloud.google.com/)
YOUTUBE_API_KEY=your_youtube_api_key_here

# Azure Blob Storage connection string (get it from your Storage Account in Azure Portal)
# Leave empty or as-is if you only want to save locally (upload_to_cloud: False in batch_launcher.py)
AZURE_STORAGE_CONNECTION_STRING=your_azure_storage_connection_string_here
