# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in your own values.
# The `.env` file is gitignored and should NEVER be committed to the repository.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────────────────

# YouTube Data API v3 key (https://console.cloud.google.com/)
YOUTUBE_API_KEY=your_youtube_api_key_here

# ── Azure Storage (optional — only needed when upload_to_cloud=True) ──────────

# Azure Blob Storage connection string (from your Storage Account in Azure Portal)
# Leave blank if you only want to save locally (upload_to_cloud: False).
AZURE_STORAGE_CONNECTION_STRING=your_azure_storage_connection_string_here

# ── Local storage path ────────────────────────────────────────────────────────

# Directory where JSON output files are written when upload_to_cloud=False.
# Local dev  : relative path works fine (e.g. ./local_data_lake)
# Docker     : bind-mounted to /data/local_data_lake inside the container.
DATA_LAKE_PATH=./local_data_lake

# ── Azure Blob container name (optional, default: youtube-comments) ───────────
BLOB_CONTAINER_NAME=youtube-comments

# ── Extraction tuning (optional, sensible defaults provided) ──────────────────

# Maximum number of comments to collect across all videos in a single run.
GLOBAL_COMMENT_LIMIT=10000

# true = only YouTube Shorts | false = long-form videos
IS_SHORT=true

# true = upload to Azure Blob Storage | false = save locally to DATA_LAKE_PATH
UPLOAD_TO_CLOUD=false

# ── Batch Launcher tuning (optional) ─────────────────────────────────────────

# How many themed requests the launcher sends per execution.
TOTAL_REQUESTS=3

# Seconds to wait between consecutive requests (avoids rate-limit spikes).
WAIT_TIME_SECONDS=4

# ── Theme catalogue (optional) ────────────────────────────────────────────────

# Comma-separated list of search themes the batch launcher cycles through.
# If omitted, the built-in list of 14 themes is used automatically.
# Entries are trimmed of spaces, so formatting is flexible.
#
# Example (uncomment and customise):
# THEMES_LIST=celebrity gossip,science documentary,politics debate,gaming drama,history explained
